          },
          {
            "matcher": { "id": "byName", "options": "uv" },
            "properties": [
              { "id": "unit", "value": "none" },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "displayName", "value": "UV Index" }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "" },
          "query": "from(bucket: \"weather\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"weather\")\n  |> filter(fn: (r) => r._field == \"solarradiation\" or r._field == \"uv\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> drop(columns: [\"station\"])\n  |> yield(name: \"mean\")",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Current Conditions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 32 },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "tempf" },
            "properties": [{ "id": "unit", "value": "fahrenheit" }, { "id": "displayName", "value": "Outdoor Temp" }]
          },
          {
            "matcher": { "id": "byName", "options": "tempinf" },
            "properties": [
              { "id": "unit", "value": "fahrenheit" },
              { "id": "displayName", "value": "Indoor Temp" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }, { "color": "green", "value": 60 }, { "color": "yellow", "value": 80 }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "humidity" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "displayName", "value": "Humidity" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "yellow", "value": null }, { "color": "green", "value": 30 }, { "color": "yellow", "value": 70 }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "windspeedmph" },
            "properties": [
              { "id": "unit", "value": "velocitymph" },
              { "id": "displayName", "value": "Wind" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 15 }, { "color": "red", "value": 30 }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "baromrelin" },
            "properties": [
              { "id": "unit", "value": "pressurehg" },
              { "id": "displayName", "value": "Pressure" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 29.8 }, { "color": "blue", "value": 30.2 }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "uv" },
            "properties": [
              { "id": "displayName", "value": "UV Index" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "orange", "value": 6 }, { "color": "red", "value": 8 }] } }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "" },
          "query": "from(bucket: \"weather\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"weather\")\n  |> filter(fn: (r) => r._field == \"tempf\" or r._field == \"tempinf\" or r._field == \"humidity\" or r._field == \"windspeedmph\" or r._field == \"baromrelin\" or r._field == \"uv\")\n  |> last()\n  |> drop(columns: [\"station\"])\n  |> yield(name: \"last\")",
          "refId": "A"
        }
      ]
