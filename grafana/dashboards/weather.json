          "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "solarradiation" },
            "properties": [
              { "id": "unit", "value": "watt" },
              { "id": "custom.axisPlacement", "value": "left" }
